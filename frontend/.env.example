# Base URL of the backend API. Empty string => same-origin (uses the Vite dev
# proxy locally). On Render set this to the backend service URL, e.g.
# VITE_API_BASE_URL=https://momentum-api.onrender.com
VITE_API_BASE_URL=

# Optional: where the Vite dev proxy forwards /api during `npm run dev`.
VITE_DEV_API_TARGET=http://localhost:8000

# =========================================================================
# Momentum backend — environment variables
# Copy to `.env` for local development. On Render these are set as service
# environment variables / secrets (never commit real secrets).
# =========================================================================

# development | production
ENV=development

# --- Datastores ----------------------------------------------------------
# Local dev can use the async SQLite fallback:
#   DATABASE_URL=sqlite+aiosqlite:///./momentum.db
# Production (Render Postgres) uses the async driver — note the +asyncpg:
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/momentum
REDIS_URL=redis://localhost:6379/0

# --- Auth / sessions -----------------------------------------------------
# Opaque sessions are stored in Redis; this signs future CSRF/signed cookies.
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=momentum_session
SESSION_TTL_SECONDS=604800
# Combined single-service deploy (API serves the UI, same origin):
#   COOKIE_SECURE=true, COOKIE_SAMESITE=lax
# Split deploy (frontend on a different origin than the API):
#   COOKIE_SECURE=true, COOKIE_SAMESITE=none  (+ set CORS_ORIGINS below)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Static frontend -----------------------------------------------------
# Path to the built React app (Vite dist). When present, FastAPI serves the UI
# from this same service. Default resolves to <repo>/frontend/dist when the
# server is started from the backend/ directory.
FRONTEND_DIST_DIR=../frontend/dist

# --- URLs / CORS ---------------------------------------------------------
# Only needed for a SPLIT deploy (frontend served from a different origin).
# For the combined single-service deploy these are unused.
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

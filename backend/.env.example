# =========================================================================
# Momentum backend — environment variables
# Copy to `.env` for local development. On Render these are set as service
# environment variables / secrets (never commit real secrets).
# =========================================================================

# development | production
ENV=development

# --- Datastores ----------------------------------------------------------
# Local dev can use the async SQLite fallback:
#   DATABASE_URL=sqlite+aiosqlite:///./momentum.db
# Production (Render Postgres) uses the async driver — note the +asyncpg:
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/momentum
REDIS_URL=redis://localhost:6379/0

# --- Auth / sessions -----------------------------------------------------
# Opaque sessions are stored in Redis; this signs future CSRF/signed cookies.
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=momentum_session
SESSION_TTL_SECONDS=604800
# Production (HTTPS, cross-site static-site <-> API): COOKIE_SECURE=true, COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- URLs / CORS ---------------------------------------------------------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
# Comma-separated list of allowed browser origins for credentialed CORS.
CORS_ORIGINS=http://localhost:5173
